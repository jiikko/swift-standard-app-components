    "Open at Login": {
      "comment": "LaunchAtLoginToggle - default Toggle label",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open at Login"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログイン時に開く"
          }
        }
      }
    },
    "Allow Open at Login in System Settings › Login Items.": {
      "comment": "LaunchAtLoginToggle - footnote shown while SMAppService status is .requiresApproval (covers both pending first approval and approval revoked by the user)",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Open at Login in System Settings › Login Items."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システム設定 › ログイン項目 で許可してください。"
          }
        }
      }
    },
    "Open Login Items Settings…": {
      "comment": "LaunchAtLoginToggle - link button that opens System Settings > Login Items",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Login Items Settings…"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログイン項目の設定を開く…"
          }
        }
      }
    },
    "Open at Login is not available for this app.": {
      "comment": "LaunchAtLoginToggle - footnote shown while SMAppService status is .notFound or unknown",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open at Login is not available for this app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリではログイン時に開く機能を利用できません。"
          }
        }
      }
    },
